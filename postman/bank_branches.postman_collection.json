                                    "key": "token",
                                    "value": "{{token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"hasAtm\": false,\n    \"phone\": \"+389 2 999 999\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/branches/1",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "branches",
                                "1"
                            ]
